# Variables para Terraform - Copia este archivo a terraform.tfvars y rellena los valores

# ====================
# AWS y EC2
# ====================
aws_region = "us-east-1"
keypair_name = "transportes_floresV"  # Nombre del .pem (sin extensión)
ssh_pem_relative_dir = "keypair"      # Carpeta donde está el .pem

# ====================
# Base de Datos RDS
# ====================
db_username = "tfvadmin"
db_password = "TU_PASSWORD_SEGURO_AQUI"  # CAMBIAR!
db_engine_version = "16.4"
db_instance_class = "db.t3.micro"
db_allocated_storage = 20
db_backup_retention_period = 0  # 0 para Free Tier

# ====================
# Imágenes Docker (GHCR)
# ====================
tfv_backend_image = "ghcr.io/akaidmaru/muni-backend-deploy:latest"
tfv_frontend_image = "ghcr.io/akaidmaru/muni-frontend-deploy:latest"

# ====================
# Dominio (NUEVO)
# ====================
# Si configuras un dominio, se agregará automáticamente a CORS
# Deja vacío ("") si solo usas la IP
app_domain = "reddmar.com"  # o "" si no tienes dominio

# URL pública del SPA (emails reset contraseña). Vacío = http://IP_EC2 (output Terraform)
# app_frontend_url = "https://www.reddmar.com"

# ====================
# Opcional: Configuración de Red
# ====================
# vpc_cidr = "10.0.0.0/16"
# public_subnet_a_cidr = "10.0.1.0/24"
# public_subnet_b_cidr = "10.0.2.0/24"
# rds_ingress_cidr = "0.0.0.0/0"  # Restringir en producción
