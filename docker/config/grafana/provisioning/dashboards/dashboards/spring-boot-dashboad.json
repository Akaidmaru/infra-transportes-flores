{
    "dashboard": {
        "id": null,
        "title": "Spring Boot Application Metrics",
        "tags": ["spring-boot", "java", "application"],
        "style": "dark",
        "timezone": "browser",
        "panels": [
            {
                "id": 1,
                "title": "JVM Memory Usage",
                "type": "graph",
                "targets": [
                    {
                        "expr": "jvm_memory_used_bytes{application=\"pallmat-app\"}",
                        "legendFormat": "{{area}}"
                    }
                ],
                "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
            },
            {
                "id": 2,
                "title": "HTTP Request Rate",
                "type": "graph",
                "targets": [
                    {
                        "expr": "rate(http_server_requests_seconds_count{application=\"pallmat-app\"}[5m])",
                        "legendFormat": "{{method}} {{uri}}"
                    }
                ],
                "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
            },
            {
                "id": 3,
                "title": "HTTP Response Time",
                "type": "graph",
                "targets": [
                    {
                        "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"pallmat-app\"}[5m]))",
                        "legendFormat": "95th percentile"
                    }
                ],
                "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
            },
            {
                "id": 4,
                "title": "Active Threads",
                "type": "stat",
                "targets": [
                    {
                        "expr": "jvm_threads_live_threads{application=\"pallmat-app\"}",
                        "legendFormat": "Active Threads"
                    }
                ],
                "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 }
            },
            {
                "id": 5,
                "title": "CPU Usage",
                "type": "stat",
                "targets": [
                    {
                        "expr": "process_cpu_usage{application=\"pallmat-app\"} * 100",
                        "legendFormat": "CPU %"
                    }
                ],
                "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 }
            },
            {
                "id": 6,
                "title": "Database Connections",
                "type": "graph",
                "targets": [
                    {
                        "expr": "hikaricp_connections_active{application=\"pallmat-app\"}",
                        "legendFormat": "Active Connections"
                    },
                    {
                        "expr": "hikaricp_connections_idle{application=\"pallmat-app\"}",
                        "legendFormat": "Idle Connections"
                    }
                ],
                "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
            },
            {
                "id": 7,
                "title": "Error Rate",
                "type": "graph",
                "targets": [
                    {
                        "expr": "rate(http_server_requests_seconds_count{application=\"pallmat-app\", status=~\"5..\"}[5m])",
                        "legendFormat": "5xx Errors"
                    },
                    {
                        "expr": "rate(http_server_requests_seconds_count{application=\"pallmat-app\", status=~\"4..\"}[5m])",
                        "legendFormat": "4xx Errors"
                    }
                ],
                "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
            }
        ],
        "time": {
            "from": "now-1h",
            "to": "now"
        },
        "refresh": "10s"
    }
}
