# Transportes Flores Vargas — generado por Ansible (no commitear)
# Backend Nest (TypeScript)

NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://{{ tfv_db_user }}:{{ tfv_db_password }}@{{ tfv_rds_host }}:{{ tfv_rds_port }}/{{ tfv_rds_dbname }}

JWT_SECRET={{ tfv_jwt_secret }}

AWS_REGION={{ aws_region }}
{% if tfv_s3_bucket is defined and tfv_s3_bucket | length > 0 %}
S3_BUCKET={{ tfv_s3_bucket }}
{% endif %}

# API pública (CORS / enlaces; el front empaquetado puede necesitar rebuild con la URL real)
PUBLIC_API_URL={{ tfv_public_api_url }}

{% if tfv_google_maps_api_key is defined and tfv_google_maps_api_key | length > 0 %}
GOOGLE_MAPS_API_KEY={{ tfv_google_maps_api_key }}
{% endif %}
{% if tfv_smtp_password is defined and tfv_smtp_password | length > 0 %}
SMTP_PASSWORD={{ tfv_smtp_password }}
{% endif %}
