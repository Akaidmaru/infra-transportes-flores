# Generado por Ansible — no commitear. NestJS + Docker Compose.

NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://{{ tfv_db_user }}:{{ tfv_db_password }}@{{ tfv_rds_host }}:{{ tfv_rds_port }}/{{ tfv_rds_dbname }}?schema=public&sslmode=require

JWT_SECRET={{ tfv_jwt_secret }}

AWS_REGION={{ aws_region }}
AWS_ACCESS_KEY_ID={{ tfv_aws_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ tfv_aws_secret_access_key }}
AWS_S3_BUCKET={{ tfv_s3_bucket }}
AWS_S3_SIGNED_URL_TTL={{ tfv_aws_s3_signed_url_ttl | default(3600) }}

# Orígenes permitidos por CORS (navegador): URL del front, p. ej. http://IP:8080 o https://tu-dominio
CORS_ORIGIN={{ tfv_cors_origin }}

# URL pública del SPA (enlaces en emails, p. ej. reset de contraseña)
FRONTEND_URL={{ tfv_frontend_url }}

# Redis en la red Docker (servicio "redis" en docker-compose)
REDIS_URL=redis://redis:6379

# URLs públicas (documentación / operadores; el front usa VITE_API_BASE_URL en build-time)
PUBLIC_API_URL={{ tfv_public_api_url }}

VERIFICATION_CODE_TTL={{ tfv_verification_code_ttl | default(600) }}
VERIFICATION_RATE_LIMIT_SECONDS={{ tfv_verification_rate_limit_seconds | default(60) }}

{% if tfv_google_maps_api_key is defined and tfv_google_maps_api_key | length > 0 %}
GOOGLE_MAPS_API_KEY={{ tfv_google_maps_api_key }}
{% endif %}

{% if tfv_brevo_api_key is defined and tfv_brevo_api_key | length > 0 %}
BREVO_API_KEY={{ tfv_brevo_api_key }}
BREVO_SENDER_EMAIL={{ tfv_brevo_sender_email | default('noreply@example.com') }}
BREVO_SENDER_NAME={{ tfv_brevo_sender_name | default('Transportes') }}
{% endif %}

# Imágenes publicadas en GHCR (GitHub Actions)
TFV_BACKEND_IMAGE={{ tfv_backend_image }}
TFV_FRONTEND_IMAGE={{ tfv_frontend_image }}
